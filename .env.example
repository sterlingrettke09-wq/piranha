# Mapbox public token — REQUIRED. Used at BUILD time for the map, parcel
# mini-map, and server-side reverse geocoding. Set in Netlify → Site settings
# → Environment variables (and locally in .env). https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# Google Gemini key — OPTIONAL. Turns on the Ask assistant. Without it the
# assistant shows "not available yet"; everything else works.
GEMINI_API_KEY=
